<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossWordsNet.ViewModels"
             x:Class="CrossWordsNet.Views.MenuView">
    
    <UserControl.Styles>
        <Style Selector="Button.MenuBtn">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="25"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.MenuBtn:pointerover">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <Style Selector="Button.MenuBtn:pressed">
            <Setter Property="Background" Value="#1ABC9C"/>
            <Setter Property="RenderTransform" Value="scale(0.95)"/>
        </Style>

    </UserControl.Styles>

    <Grid>
        <!-- Background Layer -->
        <Image x:Name="BackgroundImg" Stretch="UniformToFill" Opacity="0.3" Source="/Assets/background.png"/>
        
        <!-- Gradient Overlay -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#CC141E30" Offset="0.0"/>
                    <GradientStop Color="#CC243B55" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Main Content Card -->
        <Border Background="#99000000" 
                CornerRadius="20" 
                Padding="40" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BoxShadow="0 10 20 0 #000000">
            <StackPanel Spacing="10">
                <Image x:Name="LogoImg" Width="150" Height="150" Source="/Assets/logo.png" Margin="0,0,0,20"/>
                
                <TextBlock Text="CrossWordsNet" 
                           FontSize="48" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Foreground="#ECF0F1"
                           Margin="0,0,0,30">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" Color="Black" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button Classes="MenuBtn" Content="New Game" Command="{Binding StartNewGameCommand}"/>
                <Button Classes="MenuBtn" Content="Options" Command="{Binding OptionsCommand}"/>
                <Button Classes="MenuBtn" Content="About" Command="{Binding AboutCommand}"/>
                <Button Classes="MenuBtn" Content="Exit" Command="{Binding ExitCommand}" Background="#C0392B"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>