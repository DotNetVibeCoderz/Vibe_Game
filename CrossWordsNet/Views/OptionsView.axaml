<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossWordsNet.ViewModels"
             x:Class="CrossWordsNet.Views.OptionsView">
    <Grid>
        <Image x:Name="BackgroundImg" Stretch="UniformToFill" Opacity="0.5"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="Options" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <TextBlock Text="Sound Effects" VerticalAlignment="Center" Foreground="White" FontSize="20"/>
                <CheckBox IsChecked="{Binding SoundEnabled}" Command="{Binding ToggleSoundCommand}"/>
            </StackPanel>

            <Button Content="Back" Command="{Binding BackCommand}" Width="200" HorizontalContentAlignment="Center" FontSize="20" Background="#333" Foreground="White" Padding="10"/>
        </StackPanel>
    </Grid>
</UserControl>